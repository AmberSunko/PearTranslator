<Window x:Class="PearTranslator.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PearTranslator"
        Icon="Assets/pear.ico"
        Width="680"
        Height="660"
        MinWidth="560"
        MinHeight="540"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource GlassChromeBrush}"
        ResizeMode="CanResize">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        GlassFrameThickness="0"
                        ResizeBorderThickness="8"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>
  <Border x:Name="RootChrome"
          Margin="0"
          Background="{StaticResource GlassChromeBrush}"
          BorderThickness="0"
          CornerRadius="0"
          SnapsToDevicePixels="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Border x:Name="FooterGlassHost"
              Grid.Row="2"
              Background="Transparent"
              IsHitTestVisible="False" />
      <Border Grid.Row="0"
              Background="Transparent">
        <Grid Height="46"
              Background="Transparent"
              MouseLeftButtonDown="OnDragWindow">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0"
                      Margin="4,0,8,0"
                      Orientation="Horizontal"
                      VerticalAlignment="Center">
            <Image Width="40"
                   Height="40"
                   Margin="0,0,4,0"
                   Source="Assets/pear.png"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   SnapsToDevicePixels="True" />
            <TextBlock VerticalAlignment="Center"
                       Text="PearTranslator"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />
          </StackPanel>
          <Button Grid.Column="1"
                  Width="54"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Stretch"
                  Style="{StaticResource CloseButtonStyle}"
                  Content="×"
                  Click="OnCloseClicked" />
        </Grid>
      </Border>

      <Border x:Name="ContentPanel"
              Grid.Row="1"
              Margin="0,0,0,18"
              Padding="0"
              CornerRadius="16,0,16,16"
              Background="{StaticResource PanelBrush}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <TextBlock x:Name="ShortcutTextBlock"
                     Grid.Row="0"
                     Margin="36,18,36,18"
                     Text="选择区域：Ctrl+Alt+R  |  暂停/继续：Ctrl+Alt+T  |  隐藏当前：Ctrl+Alt+X  |  单次截图：Ctrl+Alt+S"
                     FontSize="12"
                     Foreground="{StaticResource TextSecondaryBrush}" />

          <ScrollViewer Grid.Row="1"
                        Focusable="False"
                        FocusVisualStyle="{x:Null}"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Resources>
              <Style TargetType="{x:Type ScrollBar}"
                     BasedOn="{StaticResource SettingsScrollBarStyle}" />
            </ScrollViewer.Resources>
            <StackPanel Margin="36,0,36,18">
            <TextBlock Text="基础"
                       Style="{StaticResource SettingsSectionTitleStyle}" />
            <Border Style="{StaticResource SettingsGroupBorderStyle}">
              <StackPanel>
                <Grid Style="{StaticResource SettingsRowGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0"
                              Margin="16,12,20,12"
                              VerticalAlignment="Center">
                    <TextBlock Text="界面语言"
                               Style="{StaticResource SettingsRowTitleStyle}" />
                    <TextBlock Text="切换设置界面显示语言。"
                               Style="{StaticResource SettingsRowDescriptionStyle}" />
                  </StackPanel>
                  <ComboBox x:Name="UiLanguageComboBox"
                            Grid.Column="1"
                            Width="300"
                            Margin="0,12,16,12"
                            VerticalAlignment="Center"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Language"
                            SelectionChanged="OnUiLanguageSelectionChanged" />
                </Grid>
                <Border Style="{StaticResource SettingsDividerStyle}" />

                <Grid Style="{StaticResource SettingsRowGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0"
                              Margin="16,12,20,12"
                              VerticalAlignment="Center">
                    <TextBlock Text="翻译服务"
                               Style="{StaticResource SettingsRowTitleStyle}" />
                    <TextBlock x:Name="ProviderHintText"
                               Style="{StaticResource SettingsRowDescriptionStyle}" />
                  </StackPanel>
                  <ComboBox x:Name="ProviderComboBox"
                            Grid.Column="1"
                            Width="300"
                            Margin="0,12,16,12"
                            VerticalAlignment="Center"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Kind"
                            SelectionChanged="OnProviderSelectionChanged" />
                </Grid>
                <Border Style="{StaticResource SettingsDividerStyle}" />

                <Grid Style="{StaticResource SettingsRowGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0"
                              Margin="16,12,20,12"
                              VerticalAlignment="Center">
                    <TextBlock Text="目标语言"
                               Style="{StaticResource SettingsRowTitleStyle}" />
                    <TextBlock Text="只翻译不是目标语言的内容。"
                               Style="{StaticResource SettingsRowDescriptionStyle}" />
                  </StackPanel>
                  <ComboBox x:Name="TargetLanguageComboBox"
                            Grid.Column="1"
                            Width="300"
                            Margin="0,12,16,12"
                            VerticalAlignment="Center"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Language" />
                </Grid>
                <Border Style="{StaticResource SettingsDividerStyle}" />

                <Grid Style="{StaticResource SettingsRowGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0"
                              Margin="16,12,20,12"
                              VerticalAlignment="Center">
                    <TextBlock Text="OCR 引擎"
                               Style="{StaticResource SettingsRowTitleStyle}" />
                    <TextBlock Text="识别屏幕文字的本地或系统 OCR 方案。"
                               Style="{StaticResource SettingsRowDescriptionStyle}" />
                  </StackPanel>
                  <ComboBox x:Name="OcrEngineComboBox"
                            Grid.Column="1"
                            Width="300"
                            Margin="0,12,16,12"
                            VerticalAlignment="Center"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Engine" />
                </Grid>
                <Border Style="{StaticResource SettingsDividerStyle}" />

                <Grid Style="{StaticResource SettingsRowGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0"
                              Margin="16,12,20,12"
                              VerticalAlignment="Center">
                    <TextBlock Text="OCR 语言"
                               Style="{StaticResource SettingsRowTitleStyle}" />
                    <TextBlock Text="影响本地模型和系统识别的语言偏好。"
                               Style="{StaticResource SettingsRowDescriptionStyle}" />
                  </StackPanel>
                  <ComboBox x:Name="OcrLanguageComboBox"
                            Grid.Column="1"
                            Width="300"
                            Margin="0,12,16,12"
                            VerticalAlignment="Center"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Language" />
                </Grid>
                <Border Style="{StaticResource SettingsDividerStyle}" />

                <Grid Style="{StaticResource SettingsRowGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0"
                              Margin="16,12,20,12"
                              VerticalAlignment="Center">
                    <TextBlock Text="本地资源"
                               Style="{StaticResource SettingsRowTitleStyle}" />
                    <TextBlock x:Name="RuntimeAssetsStatusText"
                               Text="正在检查 OCR 模型和 ECDICT 字典。"
                               Style="{StaticResource SettingsRowDescriptionStyle}" />
                  </StackPanel>
                  <Button x:Name="ConfigureAssetsButton"
                          Grid.Column="1"
                          Width="300"
                          Margin="0,12,16,12"
                          VerticalAlignment="Center"
                          Content="配置模型"
                          Click="OnConfigureAssetsClicked" />
                </Grid>
                <Border Style="{StaticResource SettingsDividerStyle}" />

                <Grid Style="{StaticResource SettingsRowGridStyle}">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0"
                              Margin="16,12,20,12"
                              VerticalAlignment="Center">
                    <TextBlock Text="单次显示时间"
                               Style="{StaticResource SettingsRowTitleStyle}" />
                    <TextBlock Text="单次截图覆盖层保留多久。"
                               Style="{StaticResource SettingsRowDescriptionStyle}" />
                  </StackPanel>
                  <ComboBox x:Name="OneShotDisplayComboBox"
                            Grid.Column="1"
                            Width="300"
                            Margin="0,12,16,12"
                            VerticalAlignment="Center"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Seconds" />
                </Grid>
              </StackPanel>
            </Border>

            <StackPanel x:Name="OpenAiSettingsPanel">
              <TextBlock Text="大模型"
                         Style="{StaticResource SettingsSectionTitleStyle}" />
              <Border Style="{StaticResource SettingsGroupBorderStyle}">
                <StackPanel>
                  <Grid Style="{StaticResource SettingsRowGridStyle}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Margin="16,12,20,12"
                                VerticalAlignment="Center">
                      <TextBlock Text="模型平台"
                                 Style="{StaticResource SettingsRowTitleStyle}" />
                      <TextBlock Text="选择国内或 OpenAI-compatible 平台。"
                                 Style="{StaticResource SettingsRowDescriptionStyle}" />
                    </StackPanel>
                    <ComboBox x:Name="OpenAiServiceComboBox"
                              Grid.Column="1"
                              Width="300"
                              Margin="0,12,16,12"
                              VerticalAlignment="Center"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Service"
                              SelectionChanged="OnOpenAiServiceSelectionChanged" />
                  </Grid>
                  <Border Style="{StaticResource SettingsDividerStyle}" />

                  <Grid Style="{StaticResource SettingsRowGridStyle}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Margin="16,12,20,12"
                                VerticalAlignment="Center">
                      <TextBlock Text="API 密钥"
                                 Style="{StaticResource SettingsRowTitleStyle}" />
                      <TextBlock Text="仅保存在本机配置里。"
                                 Style="{StaticResource SettingsRowDescriptionStyle}" />
                    </StackPanel>
                    <PasswordBox x:Name="OpenAiApiKeyBox"
                                 Grid.Column="1"
                                 Width="300"
                                 Margin="0,12,16,12"
                                 VerticalAlignment="Center" />
                  </Grid>
                  <Border Style="{StaticResource SettingsDividerStyle}" />

                  <Grid Style="{StaticResource SettingsRowGridStyle}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Margin="16,12,20,12"
                                VerticalAlignment="Center">
                      <TextBlock Text="模型"
                                 Style="{StaticResource SettingsRowTitleStyle}" />
                      <TextBlock Text="可获取平台模型列表，也可选择自定义。"
                                 Style="{StaticResource SettingsRowDescriptionStyle}" />
                    </StackPanel>
                    <Grid Grid.Column="1"
                          Width="300"
                          Margin="0,12,16,12"
                          VerticalAlignment="Center">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <ComboBox x:Name="OpenAiModelComboBox"
                                Grid.Column="0"
                                Margin="0,0,8,0"
                                DisplayMemberPath="Name"
                                SelectedValuePath="Value"
                                SelectionChanged="OnOpenAiModelSelectionChanged" />
                      <Button x:Name="RefreshModelsButton"
                              Grid.Column="1"
                              Content="获取模型"
                              MinHeight="34"
                              Padding="10,0"
                              FontSize="12"
                              Click="OnRefreshOpenAiModelsClicked" />
                    </Grid>
                  </Grid>

                  <StackPanel x:Name="CustomModelPanel">
                    <Border Style="{StaticResource SettingsDividerStyle}" />
                    <Grid Style="{StaticResource SettingsRowGridStyle}">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0"
                                  Margin="16,12,20,12"
                                  VerticalAlignment="Center">
                        <TextBlock Text="自定义模型"
                                   Style="{StaticResource SettingsRowTitleStyle}" />
                        <TextBlock Text="填入模型 ID。"
                                   Style="{StaticResource SettingsRowDescriptionStyle}" />
                      </StackPanel>
                      <TextBox x:Name="OpenAiCustomModelTextBox"
                               Grid.Column="1"
                               Width="300"
                               Margin="0,12,16,12"
                               VerticalAlignment="Center" />
                    </Grid>
                  </StackPanel>
                  <Border Style="{StaticResource SettingsDividerStyle}" />

                  <Grid Style="{StaticResource SettingsRowGridStyle}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Margin="16,12,20,12"
                                VerticalAlignment="Center">
                      <TextBlock Text="接口地址"
                                 Style="{StaticResource SettingsRowTitleStyle}" />
                      <TextBlock Text="留空时使用平台默认地址。"
                                 Style="{StaticResource SettingsRowDescriptionStyle}" />
                    </StackPanel>
                    <TextBox x:Name="OpenAiBaseUriTextBox"
                             Grid.Column="1"
                             Width="300"
                             Margin="0,12,16,12"
                             VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel x:Name="TraditionalSettingsPanel">
              <TextBlock Text="传统翻译"
                         Style="{StaticResource SettingsSectionTitleStyle}" />
              <Border Style="{StaticResource SettingsGroupBorderStyle}">
                <StackPanel>
                  <Grid Style="{StaticResource SettingsRowGridStyle}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Margin="16,12,20,12"
                                VerticalAlignment="Center">
                      <TextBlock x:Name="TraditionalProviderTitle"
                                 Style="{StaticResource SettingsRowTitleStyle}" />
                      <TextBlock Text="传统翻译服务的认证信息。"
                                 Style="{StaticResource SettingsRowDescriptionStyle}" />
                    </StackPanel>
                    <TextBox x:Name="TraditionalApiKeyTextBox"
                             Grid.Column="1"
                             Width="300"
                             Margin="0,12,16,12"
                             VerticalAlignment="Center" />
                  </Grid>
                  <Border Style="{StaticResource SettingsDividerStyle}" />

                  <Grid Style="{StaticResource SettingsRowGridStyle}">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Margin="16,12,20,12"
                                VerticalAlignment="Center">
                      <TextBlock Text="接口地址 / 区域 / 项目"
                                 Style="{StaticResource SettingsRowTitleStyle}" />
                      <TextBlock Text="不同服务会使用不同字段。"
                                 Style="{StaticResource SettingsRowDescriptionStyle}" />
                    </StackPanel>
                    <TextBox x:Name="TraditionalEndpointTextBox"
                             Grid.Column="1"
                             Width="300"
                             Margin="0,12,16,12"
                             VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>

            <TextBlock Text="操作"
                       Style="{StaticResource SettingsSectionTitleStyle}" />
            <Border Style="{StaticResource SettingsGroupBorderStyle}"
                    Margin="0,0,0,0">
              <Grid MinHeight="64"
                    Margin="16,10,16,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="保存翻译设置"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Click="OnSaveSettingsClicked" />
                <WrapPanel Grid.Column="1"
                           Margin="18,0,0,0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                  <CheckBox x:Name="LocalPreviewCheckBox"
                            Content="本地预翻译"
                            Margin="0,0,16,6"
                            VerticalContentAlignment="Center"
                            FontSize="13"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Checked="OnPositionOverlayChanged"
                            Unchecked="OnPositionOverlayChanged" />
                  <CheckBox x:Name="ExcludeOverlayFromCaptureCheckBox"
                            Content="不捕获覆盖层"
                            Margin="0,0,16,6"
                            VerticalContentAlignment="Center"
                            FontSize="13"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Checked="OnPositionOverlayChanged"
                            Unchecked="OnPositionOverlayChanged" />
                  <CheckBox x:Name="PositionOverlayCheckBox"
                            Content="位置覆盖"
                            Margin="0,0,16,6"
                            VerticalContentAlignment="Center"
                            FontSize="13"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Checked="OnPositionOverlayChanged"
                            Unchecked="OnPositionOverlayChanged" />
                  <CheckBox x:Name="OcrPositionTestCheckBox"
                            Content="OCR位置测试"
                            Margin="0,0,0,6"
                            VerticalContentAlignment="Center"
                            FontSize="13"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Checked="OnPositionOverlayChanged"
                            Unchecked="OnPositionOverlayChanged" />
                </WrapPanel>
              </Grid>
            </Border>
          </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>

      <Grid x:Name="FooterChrome"
            Grid.Row="2"
            Margin="18,0,18,18">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Margin="0,0,16,0"
                    VerticalAlignment="Center">
          <TextBlock x:Name="StatusText"
                     Text="准备就绪。请选择字幕区域。"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock x:Name="ConnectionStatusText"
                     Margin="0,2,0,0"
                     FontSize="12"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
          <Button Content="选择区域"
                  Margin="0,0,10,0"
                  Click="OnSelectRegionClicked" />
          <Button Content="单次截图"
                  Margin="0,0,10,0"
                  Click="OnOneShotClicked" />
          <Button x:Name="PauseButton"
                  Content="暂停"
                  Click="OnPauseClicked" />
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>

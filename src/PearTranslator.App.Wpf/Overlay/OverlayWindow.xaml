<Window x:Class="PearTranslator.App.Wpf.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:overlay="clr-namespace:PearTranslator.App.Wpf.Overlay"
        Width="720"
        Height="120"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize">
  <Window.Resources>
    <Style x:Key="OverlayIconButtonStyle"
           TargetType="Button">
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="16" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#D9FFFFFF" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="ButtonChrome"
                    Background="{TemplateBinding Background}"
                    CornerRadius="4"
                    SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver"
                       Value="True">
                <Setter TargetName="ButtonChrome"
                        Property="Background"
                        Value="#22FFFFFF" />
              </Trigger>
              <Trigger Property="IsPressed"
                       Value="True">
                <Setter TargetName="ButtonChrome"
                        Property="Background"
                        Value="#36FFFFFF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border x:Name="CaptionHost"
          Background="Transparent"
          CornerRadius="8"
          Padding="0"
          ClipToBounds="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="20" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid x:Name="ToolbarHost"
            Grid.Row="0"
            Panel.ZIndex="1"
            Height="20"
            Background="#E6202024">
        <TextBlock x:Name="ProviderLabelText"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Margin="4,0,4,0"
                   FontFamily="Microsoft YaHei UI"
                   FontSize="10"
                   FontWeight="SemiBold"
                   LineHeight="16"
                   Opacity="0.62"
                   Foreground="White" />

        <StackPanel x:Name="OverlayControlsHost"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Height="16"
                    Margin="2"
                    Background="Transparent">
          <Button x:Name="DragOverlayButton"
                  Style="{StaticResource OverlayIconButtonStyle}"
                  Content="&#x2195;"
                  ToolTip="按住拖拽 overlay"
                  PreviewMouseLeftButtonDown="OnDragOverlayButtonMouseLeftButtonDown" />
          <Button x:Name="BackgroundModeButton"
                  Style="{StaticResource OverlayIconButtonStyle}"
                  Content="&#x25D0;"
                  Margin="2,0,0,0"
                  ToolTip="切换背景透明度"
                  Click="OnToggleOverlayBackgroundClicked" />
          <Button x:Name="CaptionOutlineButton"
                  Style="{StaticResource OverlayIconButtonStyle}"
                  Content="&#x63CF;"
                  Margin="2,0,0,0"
                  ToolTip="切换文字黑边"
                  Click="OnToggleCaptionOutlineClicked" />
          <Button x:Name="SelectedRegionMarkerButton"
                  Style="{StaticResource OverlayIconButtonStyle}"
                  Content="&#x6846;"
                  Margin="2,0,0,0"
                  ToolTip="&#x663E;&#x793A;/&#x9690;&#x85CF;&#x6846;&#x9009;&#x533A;&#x57DF;"
                  Click="OnToggleSelectedRegionMarkerClicked" />
          <Button x:Name="CloseOneShotOverlayButton"
                  Style="{StaticResource OverlayIconButtonStyle}"
                  Content="x"
                  Margin="2,0,3,0"
                  Visibility="Collapsed"
                  ToolTip="关闭单次 overlay"
                  Click="OnCloseOneShotOverlayClicked" />
        </StackPanel>
      </Grid>

      <Border x:Name="DisplayBackgroundHost"
              Grid.Row="1"
              Panel.ZIndex="0"
              Background="#D0202024"
              IsHitTestVisible="False" />

      <Canvas x:Name="CaptionCanvas"
              Grid.Row="1"
              Panel.ZIndex="1"
              ClipToBounds="True"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Background="Transparent">
        <Rectangle x:Name="SourceTextDebugRectangle"
                   Stroke="#FFF08A24"
                   StrokeThickness="1.5"
                   Fill="#18F08A24"
                   IsHitTestVisible="False"
                   Panel.ZIndex="1" />
        <TextBlock x:Name="SourceTextDebugLabel"
                   Text=""
                   FontFamily="Microsoft YaHei UI"
                   FontSize="10"
                   FontWeight="SemiBold"
                   Foreground="#FFF08A24"
                   Background="#D0202024"
                   Padding="2,0"
                   TextTrimming="CharacterEllipsis"
                   IsHitTestVisible="False"
                   Panel.ZIndex="2" />
        <overlay:OutlinedTextBlock x:Name="CaptionText"
                                   Text=""
                                   TextWrapping="Wrap"
                                   TextAlignment="Left"
                                   FontFamily="Microsoft YaHei UI"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   OutlineBrush="Black"
                                   OutlineThickness="1.4"
                                   IsOutlineEnabled="True"
                                   Panel.ZIndex="3" />
      </Canvas>
    </Grid>
  </Border>
</Window>
